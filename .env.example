# Azure DevOps Configuration
AZURE_DEVOPS_ORG=sua-organizacao
AZURE_DEVOPS_PROJECT=seu-projeto
AZURE_DEVOPS_PAT=seu-personal-access-token

# Optional: Area paths para filtrar times (separados por vírgula)
# AZURE_DEVOPS_AREA_PATHS=projeto\Time1,projeto\Time2

# Cache TTL em segundos (padrão 3600 = 1 hora)
CACHE_TTL=3600
